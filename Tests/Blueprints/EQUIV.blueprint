begin
directory: equiv
file: equiv/equiv.w
    Title: Syntax Colouring Equivalency
    Author: Graham Nelson
    Language: InC
    Notation: InwebClassic

    @ This is regular code:

    =
    int main(int argc, char *argv[]) {
    	Foundation::start(argc, argv);
    	Foundation::end();
    	if (Errors::have_occurred()) return 1;
    	return 0;
    }

    @ Okay, so code extracts with no specified language:

    ```
    	int main(int argc, char *argv[]) {
    		Foundation::start(argc, argv);
    		Foundation::end();
    		if (Errors::have_occurred()) return 1;
    		return 0;
    	}
    ```

    = (text)
    	int main(int argc, char *argv[]) {
    		Foundation::start(argc, argv);
    		Foundation::end();
    		if (Errors::have_occurred()) return 1;
    		return 0;
    	}
    =

    @ The old-fashioned `text as code` notation produces:

    = (text as code)
    	int main(int argc, char *argv[]) {
    		Foundation::start(argc, argv);
    		Foundation::end();
    		if (Errors::have_occurred()) return 1;
    		return 0;
    	}
    =

